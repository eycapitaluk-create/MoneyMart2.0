# Canonical site URL for SEO (sitemap, SSR meta, og:url). Production: https://www.moneymart.co.jp
VITE_PUBLIC_SITE_ORIGIN=https://www.moneymart.co.jp
PUBLIC_SITE_URL=https://www.moneymart.co.jp

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional: web auto-logout after user inactivity (minutes). Set 0 to disable.
VITE_AUTH_IDLE_TIMEOUT_MINUTES=30
# 変数名は従来どおり。中間データ事業者（市場データAPI）のアクセスキー
VITE_MARKETSTACK_ACCESS_KEY=your_marketstack_access_key

# server-side only (Vercel / cron)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SECRET_KEY=your_supabase_secret_key
# Backward-compatible fallback (optional)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# 中間データ事業者（市場データAPI）キー — いずれか1つを設定
MARKETSTACK_ACCESS_KEY=your_marketstack_access_key
MARKETSTACK_APIKEY=your_marketstack_access_key
THENEWSAPI_API_TOKEN=your_thenewsapi_api_token
# Optional alias
THE_NEWS_API_TOKEN=your_thenewsapi_api_token
# Claude API（顧客チャット /api/chatbot、ポートフォリオ診断 /api/portfolio-diagnosis など）
# https://console.anthropic.com/ — サーバー専用。VITE_ プレフィックスは付けない。
ANTHROPIC_API_KEY=your_anthropic_api_key
# AIニュース /api/cron/ai-news: Claude を試し、失敗時は下記 Gemini があれば自動フォールバック（どちらか一方でも可）
# https://aistudio.google.com/apikey — 変数名は GEMINI_API_KEY または GOOGLE_AI_API_KEY
# GEMINI_API_KEY=your_gemini_api_key
# 省略時 gemini-2.0-flash。404 のときは gemini-1.5-flash 等へ
# AI_NEWS_GEMINI_MODEL=gemini-1.5-flash
# AIニュース（未指定時 Sonnet → Haiku、さらに失敗時 Gemini）
# AI_NEWS_MODEL=claude-3-5-sonnet-20241022
# AI_NEWS_SUMMARY_TIMEOUT_MS=45000
# 株式ページ「企業ニュース」/api/cron/company-news-brief（日次・開示ニュース連動、未指定時 Haiku）
# COMPANY_NEWS_BRIEF_MODEL=claude-3-5-haiku-20241022
# 開示を遡る時間（時間）・地域ごとのランダム選定件数
# COMPANY_NEWS_LOOKBACK_HOURS=72
# COMPANY_NEWS_DAILY_PICK=8
# 任意。未指定時チャットは Haiku 3.5（claude-3-5-haiku-20241022）
# ANTHROPIC_CHATBOT_MODEL=claude-3-5-haiku-20241022
# Optional. 비워두면 주식 717 + 펀드 335 = 1052개 전체 수집. 설정 시 해당 목록만 사용.
# MARKETSTACK_SYMBOLS=AAPL,MSFT,NVDA,...
# MARKETSTACK_SYMBOLS_TIER1=...
# MARKETSTACK_SYMBOLS_TIER2=...
# Monthly request cap used by cron safety mode (default 10000 if omitted).
MARKETSTACK_MONTHLY_BUDGET_REQUESTS=10000
# 심볼 수 상한. 0이면 무제한(1052개). 데이터 유입 확인 전엔 100~200 권장 (usage 절약)
# MARKETSTACK_MAX_SYMBOLS=100
# Weekday-only (Sat/Sun UTC skip). Default false so daily Vercel crons always ingest (e.g. JP Fri EOD on Sat).
# Set to true to save intermediate data provider API requests on weekends.
MARKETSTACK_WEEKDAYS_ONLY=false
# Skip duplicate run if one success exists today (default true)
MARKETSTACK_SKIP_IF_TODAY_SUCCESS=true
# US-only ingestion default (default true). Set false only if you want JP/API ingestion too.
MARKETSTACK_US_ONLY=true
CRON_SECRET=your-strong-cron-secret

# Document AI (receipt OCR)
GCP_PROJECT_ID=your_gcp_project_id
GCP_DOCAI_LOCATION=us
GCP_DOCAI_PROCESSOR_ID=your_document_ai_processor_id
# One of below:
GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# or base64-encoded service account json
GCP_SERVICE_ACCOUNT_JSON_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# Chat: 自社AI only (Ollama). Gemini は使用しません。
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# AWS Textract (recommended for receipt OCR)
# Prefer setting AWS_TEXTRACT_REGION explicitly for Textract endpoint stability.
AWS_TEXTRACT_REGION=ap-northeast-2
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# Optional (for temporary credentials)
AWS_SESSION_TOKEN=your_aws_session_token

NEWSDATA_API_KEY=your-newsdata-api-key

# FAQ お問い合わせフォーム → メール通知 (オプション)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=MoneyMart <noreply@moneymart.co.jp>

# Stripe（プレミアム月額 /api/billing/*）
# ローカル開発では `.env.local` に書くと読み込まれます（vite で dev サーバー再起動）。
# STRIPE_SECRET_KEY=sk_test_...（または本番 sk_live_...）
# STRIPE_WEBHOOK_SECRET=whsec_...（webhook 利用時。create-checkout のみならローカルでは省略可）
# Dashboard → Products で JPY 月額サブスクの Price を作成し API ID を設定
# STRIPE_PRICE_ID_PREMIUM_MONTHLY=price_...
# create-checkout-session がユーザーを検証する際に使用（anon で可）
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin route gate (for Stripe/Japan security questionnaire): protect /admin with Basic Auth at edge route.
# Set these ONLY on server-side env (Vercel). Do not use VITE_ prefix.
# ADMIN_BASIC_USER=your_admin_basic_username
# ADMIN_BASIC_PASS=your_strong_admin_basic_password

# A8.net（商品ページ /products）— 管理画面で発行した成果リンクURLをそのまま貼り付け（https:// から）
# 未設定の商品は公式サイト（OFFICIAL_LINKS）へ遷移します。ビルド時に反映されるため設定後は再デプロイ。
# VITE_A8_SBI_SECURITIES=
# VITE_A8_MATSUI_SECURITIES=
# VITE_A8_MATSUI_IDECO=
# VITE_A8_RAKUTEN_SECURITIES=
# VITE_A8_KINKEN_NET=
# VITE_A8_MONEX=
# VITE_A8_RAKUTEN_CARD=
# VITE_A8_PAYPAY_CARD=
# VITE_A8_EPOS=
# VITE_A8_ACOM=
# VITE_A8_SMBC_MOBIT=
# VITE_A8_SBI_LIFE=
# VITE_A8_ZURICH=
# VITE_A8_MONEYFORWARD=
# VITE_A8_GMO_GAIGA=
