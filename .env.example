VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_MARKETSTACK_ACCESS_KEY=your_marketstack_access_key

# server-side only (Vercel / cron)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SECRET_KEY=your_supabase_secret_key
# Backward-compatible fallback (optional)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# marketstack key (use one)
MARKETSTACK_ACCESS_KEY=your_marketstack_access_key
MARKETSTACK_APIKEY=your_marketstack_access_key
# Optional. If omitted, default large-cap basket is used.
MARKETSTACK_SYMBOLS=AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL,AVGO,AMD,ORCL
CRON_SECRET=your_random_secret
