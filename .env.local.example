# このファイルを `.env.local` にコピーして値を埋めてください（`.env.local` は Git に含めない）。

ANTHROPIC_API_KEY=your_claude_api_key_here

# --- Stripe（プレミアム Checkout）---
# 未設定のままだと /api/billing/create-checkout-session が 503 になります。
# Test mode: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# Products で「Recurring / 月額」の Price を作成し、API ID（price_…）を貼る
STRIPE_PRICE_ID_PREMIUM_MONTHLY=price_xxxxxxxx
# Webhook は本番または Stripe CLI で設定後に（whsec_…）
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
