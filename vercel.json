{
  "crons": [
    {
      "path": "/api/cron/yahoo-daily",
      "schedule": "30 21 * * 1-5"
    },
    {
      "path": "/api/cron/yahoo-daily",
      "schedule": "0 7 * * 1-5"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
